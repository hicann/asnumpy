# Root-level config files
include CMakeLists.txt
include pyproject.toml
include LICENSE
include README.md
include contributors.json

# Source code and resources (recursive)
recursive-include src *
recursive-include include *
recursive-include csrc *
recursive-include bindings/python *

# Examples and tests
recursive-include examples *.py *.md
recursive-include tests *.py *.cpp *.hpp

# Documentation sources
recursive-include docs *.md *.rst *.txt

# Exclude documentation build artifacts
prune docs/build
prune docs/_build

# Global exclude rules
global-exclude __pycache__ *.py[cod]
global-exclude *.a *.o *.obj *.lib *.so
global-exclude *.dll *.dylib
global-exclude *.log *.tmp *.bak *~
global-exclude .git* .github* .vscode* .idea*
global-exclude build/ dist/ *.egg-info/
global-exclude compile_commands.json
